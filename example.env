# Open Claw Stack - Environment Configuration
# Copy to .env and edit before deploying: cp example.env .env

# ── OpenClaw ──────────────────────────────────────────────────────────
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_TZ=UTC
# OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
# OPENCLAW_GATEWAY_PORT=18789
# OPENCLAW_BRIDGE_PORT=18790
# OPENCLAW_GATEWAY_BIND=lan
# OPENCLAW_CONFIG_DIR=./data/openclaw/config
# OPENCLAW_WORKSPACE_DIR=./data/openclaw/workspace

# ── MetaMCP ───────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=change-this-in-production
# METAMCP_PORT=12008
# METAMCP_APP_URL=http://localhost:12008

# ── PostgreSQL (MetaMCP backend) ──────────────────────────────────────
POSTGRES_USER=metamcp_user
POSTGRES_PASSWORD=m3t4mcp
POSTGRES_DB=metamcp_db

# ── Watchtower (auto-update) ─────────────────────────────────────────
# Poll interval in seconds (default: 86400 = 24 hours)
# WATCHTOWER_POLL_INTERVAL=86400

# ── Cloudflare Tunnel ─────────────────────────────────────────────────
# Get this from: Cloudflare Zero Trust > Networks > Tunnels > Create
CLOUDFLARE_TUNNEL_TOKEN=
